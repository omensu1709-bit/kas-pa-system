### gRPC Reconnect: Produktionsreif
```python
import grpc
import asyncio
from grpc import aio

class ResilientGrpcSubscriber:
    def __init__(self, endpoint: str):
        self.endpoint = endpoint
        self.consecutive_failures = 0
        self.max_backoff = 30.0
        
    async def subscribe_forever(self, request_builder, handler):
        while True:
            try:
                channel = aio.secure_channel(
                    self.endpoint,
                    grpc.ssl_channel_credentials(),
                    options=[
                        ('grpc.keepalive_time_ms', 8000),
                        ('grpc.keepalive_timeout_ms', 3000),
                        ('grpc.keepalive_permit_without_calls', 1),
                        ('grpc.max_receive_message_length', 64 * 1024 * 1024),
                        ('grpc.enable_retries', 1),
                    ]
                )
                
                async with channel:
                    stub = YourServiceStub(channel)
                    async for update in stub.Subscribe(request_builder()):
                        await handler(update)
                        self.consecutive_failures = 0
                        # systemd watchdog
                        notify_watchdog()
                        
            except grpc.RpcError as e:
                self.consecutive_failures += 1
                backoff = min(
                    0.5 * (2 ** self.consecutive_failures),
                    self.max_backoff
                )
                await send_telegram_alert(f"gRPC down: {e.code()}, retry in {backoff}s")
                await asyncio.sleep(backoff)
                
            except Exception as e:
                # Unbekannter Fehler → sofort alerten, trotzdem retry
                await send_telegram_alert(f"CRITICAL: {e}", priority="HIGH")
                await asyncio.sleep(5)
```

