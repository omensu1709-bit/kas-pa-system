### 7.3 LightGBM Training-Strategie

**Labeling-Strategie:**
```python
# Heuristisches Auto-Labeling
def label_transaction(tx: Transaction) -> str:
    # Rule-based Labels für bekannte Bot-Programme
    if tx.program_id in KNOWN_SANDWICH_PROGRAMS:
        return 'sandwich_bot'
    if tx.program_id in KNOWN_LIQUIDATION_PROGRAMS and tx.instruction == 'liquidate':
        return 'liquidation_bot'
    
    # Feature-basierte Labels
    features = extract_features(tx)
    
    if (features['bundle_size'] == 3 and 
        features['same_pool_tx_count_in_slot'] >= 3 and
        features['inter_tx_delay_ms'] < 1):
        return 'sandwich_bot'
    
    if (features['swap_hop_count'] >= 2 and 
        features['token_balance_net_change'] < 0.01):
        return 'arbitrage_bot'
    
    if (features['token_age_slots'] < 5 and 
        features['is_pumpfun_interaction']):
        return 'sniper_bot'
    
    if features['wallet_tx_count_24h'] > 200:
        return 'automated_bot'
    
    return 'human'

# Konfidenz-Scoring
CONFIDENCE_RULES = {
    'sandwich_bot': lambda f: min(0.5 + f['bundle_size']*0.1 + f['jito_tip_ratio']*0.3, 0.99),
    'arbitrage_bot': lambda f: min(0.4 + f['swap_hop_count']*0.15 + (1-f['tx_failure_rate'])*0.2, 0.99),
    'sniper_bot': lambda f: min(0.3 + (1/(f['token_age_slots']+1))*0.5, 0.99),
}
```

