### 6.2 Dune SQL – Bot-Detection Queries

**Sandwich-Bot Identifikation:**
```sql
-- Sandwich-Triples erkennen
WITH swap_triplets AS (
  SELECT 
    slot,
    array_agg(tx_id ORDER BY tx_index) as txs,
    array_agg(wallet ORDER BY tx_index) as wallets,
    pool_id,
    count(*) as tx_count
  FROM solana.dex_swaps
  WHERE block_time >= now() - interval '24 hours'
  GROUP BY slot, pool_id
  HAVING count(*) >= 3
)
SELECT 
  slot,
  pool_id,
  wallets[1] as frontrun_wallet,
  wallets[2] as victim_wallet, 
  wallets[3] as backrun_wallet,
  tx_count
FROM swap_triplets
WHERE wallets[1] = wallets[3]  -- Bot kauft und verkauft
  AND wallets[1] != wallets[2]  -- Victim ist anders
ORDER BY slot DESC;

-- Arbitrage-Bot Erkennung
SELECT 
  tx_id,
  fee_payer,
  count(DISTINCT program_id) as dex_count,
  sum(CASE WHEN token_in = token_out THEN 1 ELSE 0 END) as closed_loop,
  priority_fee_microlamports
FROM solana.transactions t
JOIN solana.instructions i ON t.tx_id = i.tx_id
WHERE block_time >= now() - interval '1 hour'
  AND dex_count >= 2
  AND closed_loop > 0
GROUP BY tx_id, fee_payer, priority_fee_microlamports
HAVING dex_count >= 2
ORDER BY priority_fee_microlamports DESC;
```

