{
  "name": "solana-stream",
  "version": "1.0.0",
  "description": "Hybrid Solana streaming with Helius LaserStream + ChainStack Yellowstone",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=ingestor",
    "start:ingestor": "node ingestor/dist/index.js",
    "start:ranker": "python3 -m ranker.src.main",
    "start:analyzer": "python3 -m analyzer.src.main",
    "dev:ingestor": "tsc && node ingestor/dist/index.js",
    "test:connection": "node scripts/test-connections.js"
  },
  "workspaces": [
    "ingestor",
    "ranker",
    "analyzer",
    "data"
  ],
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ws": "^8.18.1",
    "playwright": "^1.59.1",
    "ws": "^8.20.0"
  }
}
